@inject NavigationManager Navigation
@inject GestionConsultorio.Mobile.Services.Interfaces.IAlertService AlertService
@inject GestionConsultorio.Mobile.Services.Interfaces.ISesionService SesionService

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<aside class="sidebar" id="sidebar">
    <div>
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">
                🩺
            </div>

            <div class="sidebar-brand-text">
                <h1>Centro Médico Toay</h1>
                <span>Sistema de Gestión</span>
            </div>
        </div>

        <nav>
            <div class="nav-section-title">Principal</div>

            <NavLink class="nav-link" href="/dashboard" Match="NavLinkMatch.All">
                <span class="nav-link-icon">🏠</span>
                <span>Inicio</span>
            </NavLink>

            @if (PuedeVerAgenda)
            {
                <NavLink class="nav-link" href="/agenda">
                    <span class="nav-link-icon">📅</span>
                    <span>Agenda</span>
                </NavLink>
            }

            @if (PuedeVerTurnos)
            {
                <NavLink class="nav-link" href="/turnos">
                    <span class="nav-link-icon">🕒</span>
                    <span>Turnos</span>
                </NavLink>
            }

            @if (PuedeVerGestion)
            {
                <div class="nav-section-title">Gestión</div>
            }

            @if (PuedeVerPacientes)
            {
                <NavLink class="nav-link" href="/pacientes">
                    <span class="nav-link-icon">👥</span>
                    <span>Pacientes</span>
                </NavLink>
            }

            @if (PuedeVerMedicos)
            {
                <NavLink class="nav-link" href="/medicos">
                    <span class="nav-link-icon">👨‍⚕️</span>
                    <span>Médicos</span>
                </NavLink>
            }

            @if (PuedeVerEspecialidades)
            {
                <NavLink class="nav-link" href="/especialidades">
                    <span class="nav-link-icon">🏥</span>
                    <span>Especialidades</span>
                </NavLink>
            }

            @if (PuedeVerConsultorios)
            {
                <NavLink class="nav-link" href="/consultorios">
                    <span class="nav-link-icon">🚪</span>
                    <span>Consultorios</span>
                </NavLink>
            }

            @if (PuedeVerHistoriales)
            {
                <NavLink class="nav-link" href="/historiales">
                    <span class="nav-link-icon">📋</span>
                    <span>Historial clínico</span>
                </NavLink>
            }
        </nav>
    </div>

    <div class="sidebar-footer">
        <div class="user-mini-card">
            <div class="user-avatar">
                @InicialUsuario
            </div>

            <div class="user-info">
                <strong>@NombreUsuario</strong>
                <span>@RolUsuario</span>
            </div>
        </div>

        <button type="button" class="nav-link logout-button" @onclick="CerrarSesionAsync">
            <span class="nav-link-icon">🚪</span>
            <span>Cerrar sesión</span>
        </button>
    </div>
</aside>

@code {
    private string NombreUsuario = "Usuario";
    private string RolUsuario = string.Empty;
    private string InicialUsuario = "U";

    private bool EsAdministrador =>
        string.Equals(RolUsuario, "Administrador", StringComparison.OrdinalIgnoreCase);

    private bool EsRecepcionista =>
        string.Equals(RolUsuario, "Recepcionista", StringComparison.OrdinalIgnoreCase);

    private bool EsMedico =>
        string.Equals(RolUsuario, "Medico", StringComparison.OrdinalIgnoreCase);

    private bool PuedeVerAgenda =>
        EsRecepcionista || EsMedico;

    private bool PuedeVerTurnos =>
        EsRecepcionista;

    private bool PuedeVerPacientes =>
        EsRecepcionista || EsMedico;

    private bool PuedeVerMedicos =>
        EsAdministrador;

    private bool PuedeVerEspecialidades =>
        EsAdministrador;

    private bool PuedeVerConsultorios =>
        EsAdministrador;

    private bool PuedeVerHistoriales =>
        false;

    private bool PuedeVerGestion =>
        PuedeVerPacientes ||
        PuedeVerMedicos ||
        PuedeVerEspecialidades ||
        PuedeVerConsultorios ||
        PuedeVerHistoriales;

    protected override void OnInitialized()
    {
        NombreUsuario = SesionService.ObtenerNombreCompleto() ?? "Usuario";
        RolUsuario = SesionService.ObtenerRol() ?? string.Empty;

        if (!string.IsNullOrWhiteSpace(NombreUsuario))
        {
            InicialUsuario = NombreUsuario.Substring(0, 1).ToUpper();
        }
    }

    private async Task CerrarSesionAsync()
    {
        var confirmado = await AlertService.ConfirmAsync(
            "Cerrar sesión",
            "¿Seguro que querés salir del sistema?",
            "Sí, cerrar sesión");

        if (!confirmado)
        {
            return;
        }

        SesionService.CerrarSesion();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}