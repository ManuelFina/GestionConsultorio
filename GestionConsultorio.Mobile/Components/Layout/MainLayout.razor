@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="app-shell">
    <NavMenu />

    <main class="main-content">
        <div class="topbar">
            <button class="menu-toggle" id="menuToggle" type="button">
                ☰
            </button>

            <div class="topbar-title">
                <strong>Sistema de Gestión</strong>
                <span>Centro Medico Toay</span>
            </div>
        </div>

        @Body

        <footer class="app-footer">
            <div>
                <strong>Centro Médico Toay</strong>
                <span>Sistema de Gestión Médica</span>
            </div>

            <small>© 2026 - Manuel Fina Echarri</small>
        </footer>
    </main>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("sidebarMenu.init");
        }
    }
}