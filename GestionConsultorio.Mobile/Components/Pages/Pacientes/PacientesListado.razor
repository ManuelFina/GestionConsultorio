@page "/pacientes"

@using GestionConsultorio.Mobile.Services.Interfaces
@using GestionConsultorio.Shared.Models

@inject IPacienteService PacienteService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-title">
        <h2>Pacientes</h2>
        <p>Gestión de pacientes registrados en el consultorio</p>
    </div>

    <button class="btn btn-primary" @onclick="IrNuevoPaciente">
        + Nuevo paciente
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(MensajeError))
{
    <div class="alert alert-error">
        @MensajeError
    </div>
}

@if (!string.IsNullOrWhiteSpace(MensajeExito))
{
    <div class="alert alert-success">
        @MensajeExito
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="toolbar">
            <div class="search-box">
                <input class="form-control"
                       placeholder="Buscar por nombre, DNI, obra social..."
                       @bind="TextoBusqueda"
                       @bind:event="oninput" />
            </div>

            <button class="btn btn-outline" @onclick="CargarPacientesAsync">
                Actualizar
            </button>
        </div>

        @if (Cargando)
        {
            <p class="empty-text">Cargando pacientes...</p>
        }
        else if (!PacientesFiltrados.Any())
        {
            <p class="empty-text">No se encontraron pacientes.</p>
        }
        else
        {
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Paciente</th>
                            <th>DNI</th>
                            <th>Contacto</th>
                            <th>Obra social</th>
                            <th>Fecha nacimiento</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var paciente in PacientesFiltrados)
                        {
                            <tr>
                                <td>
                                    <strong>@paciente.NombreCompleto</strong>
                                    <div class="table-subtext">@paciente.Direccion</div>
                                </td>

                                <td>@paciente.Dni</td>

                                <td>
                                    <div>@paciente.Telefono</div>
                                    <div class="table-subtext">@paciente.Email</div>
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(paciente.ObraSocial))
                                    {
                                        <span class="badge badge-info">@paciente.ObraSocial</span>
                                    }
                                    else
                                    {
                                        <span class="table-subtext">Sin obra social</span>
                                    }
                                </td>

                                <td>@paciente.FechaNacimiento.ToString("dd/MM/yyyy")</td>

                                <td>
                                    <div class="actions">
                                        <button class="action-btn" @onclick="() => VerDetalle(paciente.Id)">
                                            Ver
                                        </button>

                                        <button class="action-btn" @onclick="() => EditarPaciente(paciente.Id)">
                                            Editar
                                        </button>

                                        <button class="action-btn action-danger" @onclick="() => EliminarPacienteAsync(paciente.Id)">
                                            Eliminar
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool Cargando = true;
    private string MensajeError = string.Empty;
    private string MensajeExito = string.Empty;
    private string TextoBusqueda = string.Empty;

    private List<Paciente> Pacientes = new();

    private IEnumerable<Paciente> PacientesFiltrados =>
        string.IsNullOrWhiteSpace(TextoBusqueda)
            ? Pacientes
            : Pacientes.Where(p =>
                p.NombreCompleto.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ||
                p.Dni.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ||
                p.ObraSocial.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ||
                p.Email.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await CargarPacientesAsync();
    }

    private async Task CargarPacientesAsync()
    {
        Cargando = true;
        MensajeError = string.Empty;
        MensajeExito = string.Empty;

        var resultado = await PacienteService.ObtenerTodosAsync();

        if (!resultado.Exitoso)
        {
            MensajeError = resultado.Mensaje;
            Cargando = false;
            return;
        }

        Pacientes = resultado.Data ?? new List<Paciente>();
        Cargando = false;
    }

    private void IrNuevoPaciente()
    {
        Navigation.NavigateTo("/pacientes/nuevo");
    }

    private void VerDetalle(int id)
    {
        Navigation.NavigateTo($"/pacientes/{id}");
    }

    private void EditarPaciente(int id)
    {
        Navigation.NavigateTo($"/pacientes/editar/{id}");
    }

    private async Task EliminarPacienteAsync(int id)
    {
        MensajeError = string.Empty;
        MensajeExito = string.Empty;

        var resultado = await PacienteService.EliminarAsync(id);

        if (!resultado.Exitoso)
        {
            MensajeError = resultado.Mensaje;
            return;
        }

        MensajeExito = "Paciente eliminado correctamente.";
        await CargarPacientesAsync();
    }
}