@page "/pacientes"

@using GestionConsultorio.Mobile.Services.Interfaces
@using GestionConsultorio.Shared.Models

@inject IPacienteService PacienteService
@inject IAlertService AlertService
@inject ISesionService SesionService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-title">
        <h2>@TituloPagina</h2>
        <p>@SubtituloPagina</p>
    </div>

    @if (PuedeCrearPacientes && !MostrandoInactivos)
    {
        <button class="btn btn-primary" @onclick="IrNuevoPaciente">
            + Nuevo paciente
        </button>
    }
</div>

@if (!string.IsNullOrWhiteSpace(MensajeError))
{
    <div class="alert alert-error">
        @MensajeError
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="toolbar">
            <div class="search-box">
                <input class="form-control"
                       placeholder="Buscar por nombre, DNI, obra social..."
                       @bind="TextoBusqueda"
                       @bind:event="oninput" />
            </div>

            @if (PuedeModificarPacientes)
            {
                <button class="@ClaseBotonActivos" @onclick="MostrarPacientesActivosAsync">
                    Activos
                </button>

                <button class="@ClaseBotonInactivos" @onclick="MostrarPacientesInactivosAsync">
                    Dados de baja
                </button>
            }

            <button class="btn btn-outline" @onclick="CargarPacientesAsync">
                Actualizar
            </button>
        </div>

        @if (Cargando)
        {
            <p class="empty-text">@TextoCargando</p>
        }
        else if (!PacientesFiltrados.Any())
        {
            <p class="empty-text">@TextoSinPacientes</p>
        }
        else
        {
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Paciente</th>
                            <th>DNI</th>
                            <th>Contacto</th>
                            <th>Obra social</th>
                            <th>Fecha nacimiento</th>

                            @if (MostrandoInactivos)
                            {
                                <th>Fecha baja</th>
                            }

                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var paciente in PacientesFiltrados)
                        {
                            <tr>
                                <td>
                                    <strong>@paciente.NombreCompleto</strong>
                                    <div class="table-subtext">@MostrarDato(paciente.Direccion)</div>

                                    @if (MostrandoInactivos)
                                    {
                                        <span class="badge badge-danger">Dado de baja</span>
                                    }
                                </td>

                                <td>@paciente.Dni</td>

                                <td>
                                    <div>@MostrarDato(paciente.Telefono)</div>
                                    <div class="table-subtext">@MostrarDato(paciente.Email)</div>
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(paciente.ObraSocial))
                                    {
                                        <span class="badge badge-info">@paciente.ObraSocial</span>
                                    }
                                    else
                                    {
                                        <span class="table-subtext">Sin obra social</span>
                                    }
                                </td>

                                <td>@paciente.FechaNacimiento.ToString("dd/MM/yyyy")</td>

                                @if (MostrandoInactivos)
                                {
                                    <td>@MostrarFechaBaja(paciente.FechaBaja)</td>
                                }

                                <td>
                                    <div class="actions">
                                        @if (MostrandoInactivos)
                                        {
                                            <button class="action-btn" @onclick="@(() => ReactivarPacienteAsync(paciente.Id))">
                                                Reactivar
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="action-btn" @onclick="@(() => VerDetalle(paciente.Id))">
                                                Ver
                                            </button>

                                            @if (PuedeModificarPacientes)
                                            {
                                                <button class="action-btn" @onclick="@(() => EditarPaciente(paciente.Id))">
                                                    Editar
                                                </button>

                                                <button class="action-btn action-danger" @onclick="@(() => DarDeBajaPacienteAsync(paciente.Id))">
                                                    Dar de baja
                                                </button>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool Cargando = true;
    private bool MostrandoInactivos;
    private string MensajeError = string.Empty;
    private string TextoBusqueda = string.Empty;
    private string RolUsuario = string.Empty;

    private List<Paciente> Pacientes = new();

    private bool EsRecepcionista =>
        string.Equals(RolUsuario, "Recepcionista", StringComparison.OrdinalIgnoreCase);

    private bool EsMedico =>
        string.Equals(RolUsuario, "Medico", StringComparison.OrdinalIgnoreCase);

    private bool PuedeCrearPacientes =>
        EsRecepcionista;

    private bool PuedeModificarPacientes =>
        EsRecepcionista;

    private string TituloPagina =>
        MostrandoInactivos ? "Pacientes dados de baja" : "Pacientes";

    private string SubtituloPagina
    {
        get
        {
            if (MostrandoInactivos)
                return "Pacientes inactivos que pueden ser reactivados";

            if (EsMedico)
                return "Pacientes asociados a tus turnos y atenciones";

            return "Gestión de pacientes registrados en el consultorio";
        }
    }

    private string TextoCargando =>
        MostrandoInactivos
            ? "Cargando pacientes dados de baja..."
            : "Cargando pacientes...";

    private string TextoSinPacientes
    {
        get
        {
            if (MostrandoInactivos)
                return "No hay pacientes dados de baja.";

            if (EsMedico)
                return "No tenés pacientes asociados por el momento.";

            return "No se encontraron pacientes.";
        }
    }

    private string ClaseBotonActivos =>
        MostrandoInactivos ? "btn btn-outline" : "btn btn-primary";

    private string ClaseBotonInactivos =>
        MostrandoInactivos ? "btn btn-primary" : "btn btn-outline";

    private IEnumerable<Paciente> PacientesFiltrados =>
        string.IsNullOrWhiteSpace(TextoBusqueda)
            ? Pacientes
            : Pacientes.Where(p =>
                (p.NombreCompleto?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Dni?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.ObraSocial?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Email?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        RolUsuario = SesionService.ObtenerRol() ?? string.Empty;

        await CargarPacientesAsync();
    }

    private async Task CargarPacientesAsync()
    {
        Cargando = true;
        MensajeError = string.Empty;

        var resultado = MostrandoInactivos && PuedeModificarPacientes
            ? await PacienteService.ObtenerInactivosAsync()
            : await PacienteService.ObtenerTodosAsync();

        if (!resultado.Exitoso)
        {
            MensajeError = resultado.Mensaje;
            Cargando = false;
            return;
        }

        Pacientes = resultado.Data ?? new List<Paciente>();
        Cargando = false;
    }

    private async Task MostrarPacientesActivosAsync()
    {
        MostrandoInactivos = false;
        TextoBusqueda = string.Empty;
        await CargarPacientesAsync();
    }

    private async Task MostrarPacientesInactivosAsync()
    {
        MostrandoInactivos = true;
        TextoBusqueda = string.Empty;
        await CargarPacientesAsync();
    }

    private void IrNuevoPaciente()
    {
        Navigation.NavigateTo("/pacientes/nuevo");
    }

    private void VerDetalle(int id)
    {
        Navigation.NavigateTo($"/pacientes/{id}");
    }

    private void EditarPaciente(int id)
    {
        Navigation.NavigateTo($"/pacientes/editar/{id}");
    }

    private async Task DarDeBajaPacienteAsync(int id)
    {
        MensajeError = string.Empty;

        var confirmado = await AlertService.ConfirmAsync(
            "Dar de baja paciente",
            "¿Seguro que querés dar de baja este paciente? No se eliminarán sus turnos ni su historial clínico.",
            "Sí, dar de baja");

        if (!confirmado)
            return;

        var resultado = await PacienteService.EliminarAsync(id);

        if (!resultado.Exitoso)
        {
            await AlertService.ErrorAsync(
                "No se pudo dar de baja",
                resultado.Mensaje);

            return;
        }

        await AlertService.SuccessAsync(
            "Paciente dado de baja",
            "El paciente fue dado de baja correctamente.");

        await CargarPacientesAsync();
    }

    private async Task ReactivarPacienteAsync(int id)
    {
        MensajeError = string.Empty;

        var confirmado = await AlertService.ConfirmAsync(
            "Reactivar paciente",
            "¿Seguro que querés reactivar este paciente? Volverá a aparecer en el listado principal.",
            "Sí, reactivar");

        if (!confirmado)
            return;

        var resultado = await PacienteService.ReactivarAsync(id);

        if (!resultado.Exitoso)
        {
            await AlertService.ErrorAsync(
                "No se pudo reactivar",
                resultado.Mensaje);

            return;
        }

        await AlertService.SuccessAsync(
            "Paciente reactivado",
            "El paciente volvió a estar activo correctamente.");

        await CargarPacientesAsync();
    }

    private static string MostrarDato(string? valor)
    {
        return string.IsNullOrWhiteSpace(valor) ? "-" : valor;
    }

    private static string MostrarFechaBaja(DateTime? fechaBaja)
    {
        return fechaBaja.HasValue
            ? fechaBaja.Value.ToString("dd/MM/yyyy")
            : "-";
    }
}