@page "/pacientes/{PacienteId:int}"

@using GestionConsultorio.Mobile.Services.Interfaces
@using GestionConsultorio.Shared.Models

@inject IPacienteService PacienteService
@inject ITurnoService TurnoService
@inject ISesionService SesionService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-title">
        <h2>Detalle del paciente</h2>
        <p>@SubtituloPagina</p>
    </div>

    <div class="actions">
        <button class="btn btn-outline" @onclick="Volver">
            Volver
        </button>

        @if (PuedeEditarPaciente)
        {
            <button class="btn btn-primary" @onclick="EditarPaciente">
                Editar paciente
            </button>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(MensajeError))
{
    <div class="alert alert-error">
        @MensajeError
    </div>
}

@if (Cargando)
{
    <div class="card">
        <div class="card-body">
            <p class="empty-text">Cargando información del paciente...</p>
        </div>
    </div>
}
else if (Paciente is null)
{
    <div class="card">
        <div class="card-body">
            <p class="empty-text">No se encontró el paciente solicitado.</p>
        </div>
    </div>
}
else
{
    <div class="patient-detail-grid">
        <div class="card">
            <div class="card-body">
                <div class="patient-profile">
                    <div class="patient-avatar">
                        @InicialPaciente
                    </div>

                    <div>
                        <h3>@Paciente.NombreCompleto</h3>
                        <p>DNI @Paciente.Dni</p>
                    </div>
                </div>

                <div class="detail-list">
                    <div class="detail-item">
                        <span>Fecha de nacimiento</span>
                        <strong>@Paciente.FechaNacimiento.ToString("dd/MM/yyyy")</strong>
                    </div>

                    <div class="detail-item">
                        <span>Teléfono</span>
                        <strong>@MostrarDato(Paciente.Telefono)</strong>
                    </div>

                    <div class="detail-item">
                        <span>Email</span>
                        <strong>@MostrarDato(Paciente.Email)</strong>
                    </div>

                    <div class="detail-item">
                        <span>Dirección</span>
                        <strong>@MostrarDato(Paciente.Direccion)</strong>
                    </div>

                    <div class="detail-item">
                        <span>Obra social</span>
                        <strong>@MostrarDato(Paciente.ObraSocial)</strong>
                    </div>

                    <div class="detail-item">
                        <span>Número de afiliado</span>
                        <strong>@MostrarDato(Paciente.NumeroAfiliado)</strong>
                    </div>
                </div>

                @if (PuedeVerHistorialClinico)
                {
                    <div class="patient-history-cta">
                        <div>
                            <strong>Historial clínico del paciente</strong>
                            <span>Consultá los registros médicos asociados a este paciente.</span>
                        </div>

                        <button class="btn btn-primary" @onclick="IrHistorialClinico">
                            Ver historial clínico
                        </button>
                    </div>
                }
            </div>
        </div>

        <div class="patient-side-column">
            <div class="card">
                <div class="card-body">
                    <div class="section-header">
                        <div>
                            <h3>Turnos del paciente</h3>
                            <p>Últimos turnos registrados</p>
                        </div>
                    </div>

                    @if (!Turnos.Any())
                    {
                        <p class="empty-text">El paciente no tiene turnos registrados.</p>
                    }
                    else
                    {
                        @foreach (var turno in Turnos.Take(5))
                        {
                            <div class="turno-item">
                                <div class="turno-item-header">
                                    <span class="turno-time">
                                        @turno.Fecha.ToString("dd/MM/yyyy") - @turno.HoraInicio.ToString("HH:mm")
                                    </span>

                                    <span class="@ObtenerClaseEstado(turno.Estado.ToString())">
                                        @turno.Estado
                                    </span>
                                </div>

                                <div class="turno-detail">
                                    Médico: @(turno.Medico?.NombreCompleto ?? "Sin médico")
                                </div>

                                <div class="turno-detail">
                                    Especialidad: @(turno.Medico?.Especialidad?.Nombre ?? "Sin especialidad")
                                </div>

                                <div class="turno-detail">
                                    Consultorio: @(turno.Consultorio?.Nombre ?? "Sin consultorio")
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int PacienteId { get; set; }

    private Paciente? Paciente;
    private List<Turno> Turnos = new();

    private bool Cargando = true;
    private string MensajeError = string.Empty;
    private string RolUsuario = string.Empty;

    private bool EsRecepcionista =>
        string.Equals(RolUsuario, "Recepcionista", StringComparison.OrdinalIgnoreCase);

    private bool EsMedico =>
        string.Equals(RolUsuario, "Medico", StringComparison.OrdinalIgnoreCase);

    private bool PuedeEditarPaciente =>
        EsRecepcionista;

    private bool PuedeVerHistorialClinico =>
        EsMedico;

    private string SubtituloPagina =>
        EsMedico
            ? "Información del paciente y acceso a su historial clínico"
            : "Información general y turnos del paciente";

    private string InicialPaciente =>
        string.IsNullOrWhiteSpace(Paciente?.NombreCompleto)
            ? "P"
            : Paciente.NombreCompleto.Substring(0, 1).ToUpper();

    protected override async Task OnInitializedAsync()
    {
        RolUsuario = SesionService.ObtenerRol() ?? string.Empty;

        await CargarDetalleAsync();
    }

    private async Task CargarDetalleAsync()
    {
        Cargando = true;
        MensajeError = string.Empty;

        var pacienteResponse = await PacienteService.ObtenerPorIdAsync(PacienteId);

        if (!pacienteResponse.Exitoso)
        {
            MensajeError = pacienteResponse.Mensaje;
            Cargando = false;
            return;
        }

        Paciente = pacienteResponse.Data;

        var turnosResponse = await TurnoService.ObtenerPorPacienteAsync(PacienteId);

        if (turnosResponse.Exitoso)
        {
            Turnos = turnosResponse.Data ?? new List<Turno>();
        }

        Cargando = false;
    }

    private void IrHistorialClinico()
    {
        Navigation.NavigateTo($"/historiales/paciente/{PacienteId}");
    }

    private void EditarPaciente()
    {
        Navigation.NavigateTo($"/pacientes/editar/{PacienteId}");
    }

    private void Volver()
    {
        Navigation.NavigateTo("/pacientes");
    }

    private static string MostrarDato(string? valor)
    {
        return string.IsNullOrWhiteSpace(valor) ? "No registrado" : valor;
    }

    private static string ObtenerClaseEstado(string estado)
    {
        return estado switch
        {
            "Confirmado" => "badge badge-success",
            "Pendiente" => "badge badge-warning",
            "Cancelado" => "badge badge-danger",
            "Atendido" => "badge badge-info",
            "Ausente" => "badge badge-danger",
            "Reprogramado" => "badge badge-warning",
            _ => "badge badge-info"
        };
    }
}