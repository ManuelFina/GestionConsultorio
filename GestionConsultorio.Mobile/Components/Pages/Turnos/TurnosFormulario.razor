@page "/turnos/nuevo"
@page "/turnos/editar/{TurnoId:int}"

@using GestionConsultorio.Mobile.Services.Interfaces
@using GestionConsultorio.Shared.Models
@using GestionConsultorio.Shared.Enums

@inject ITurnoService TurnoService
@inject IPacienteService PacienteService
@inject IMedicoService MedicoService
@inject IEspecialidadService EspecialidadService
@inject IConsultorioService ConsultorioService
@inject IAlertService AlertService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-title">
        <h2>@TituloPagina</h2>
        <p>@SubtituloPagina</p>
    </div>

    <button class="btn btn-outline" @onclick="Volver">
        Volver
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(MensajeError))
{
    <div class="alert alert-error">
        @MensajeError
    </div>
}

<div class="card">
    <div class="card-body">
        @if (Cargando)
        {
            <p class="empty-text">Cargando información del turno...</p>
        }
        else
        {
            <EditForm Model="Turno" OnValidSubmit="GuardarAsync">
                <DataAnnotationsValidator />

                <div class="form-grid">
                    <div>
                        <label class="form-label">Paciente</label>
                        <InputSelect class="form-control" @bind-Value="Turno.PacienteId">
                            <option value="0">Seleccionar paciente</option>

                            @foreach (var paciente in Pacientes)
                            {
                                <option value="@paciente.Id">
                                    @paciente.NombreCompleto - DNI @paciente.Dni
                                </option>
                            }
                        </InputSelect>
                    </div>

                    <div>
                        <label class="form-label">Especialidad</label>
                        <select class="form-control"
                                value="@EspecialidadSeleccionadaId"
                                @onchange="OnEspecialidadChanged">
                            <option value="0">Seleccionar especialidad</option>

                            @foreach (var especialidad in Especialidades)
                            {
                                <option value="@especialidad.Id">
                                    @especialidad.Nombre
                                </option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Médico</label>
                        <select class="form-control"
                                value="@Turno.MedicoId"
                                disabled="@(EspecialidadSeleccionadaId == 0 || !MedicosFiltrados.Any())"
                                @onchange="OnMedicoChanged">
                            <option value="0">
                                @TextoSelectorMedico
                            </option>

                            @foreach (var medico in MedicosFiltrados)
                            {
                                <option value="@medico.Id">
                                    @medico.NombreCompleto
                                </option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Consultorio</label>
                        <select class="form-control"
                                value="@Turno.ConsultorioId"
                                @onchange="OnConsultorioChanged">
                            <option value="0">Seleccionar consultorio</option>

                            @foreach (var consultorio in Consultorios)
                            {
                                <option value="@consultorio.Id">
                                    @consultorio.Nombre
                                </option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Fecha</label>
                        <input type="date"
                               class="form-control"
                               value="@FechaTurno.ToString("yyyy-MM-dd")"
                               @onchange="OnFechaInputChangedAsync" />
                    </div>

                    @if (EsEdicion)
                    {
                        <div>
                            <label class="form-label">Estado</label>
                            <InputSelect class="form-control" @bind-Value="Turno.Estado">
                                <option value="@EstadoTurno.Pendiente">Pendiente</option>
                                <option value="@EstadoTurno.Confirmado">Confirmado</option>
                                <option value="@EstadoTurno.Atendido">Atendido</option>
                                <option value="@EstadoTurno.Cancelado">Cancelado</option>
                                <option value="@EstadoTurno.Reprogramado">Reprogramado</option>
                                <option value="@EstadoTurno.Ausente">Ausente</option>
                            </InputSelect>
                        </div>
                    }

                    <div class="form-grid-full">
                        <label class="form-label">Horarios disponibles</label>

                        <div class="turno-horarios-box">
                            <div class="turno-horarios-header">
                                <div>
                                    <strong>@FechaTurno.ToString("dd/MM/yyyy")</strong>
                                    <span>@NombreMedicoSeleccionado</span>
                                </div>

                                <div class="turno-horarios-legend">
                                    <span>
                                        <i class="legend-dot legend-free"></i>
                                        Libres
                                    </span>

                                    <span>
                                        <i class="legend-dot legend-busy"></i>
                                        Ocupados
                                    </span>
                                </div>
                            </div>

                            @if (!PuedeMostrarHorarios)
                            {
                                <p class="empty-text">
                                    Seleccioná especialidad, médico y consultorio para ver los horarios disponibles.
                                </p>
                            }
                            else if (CargandoHorarios)
                            {
                                <p class="empty-text">Cargando horarios disponibles...</p>
                            }
                            else if (!HorariosDisponibles.Any())
                            {
                                <p class="empty-text">No hay horarios configurados para esta fecha.</p>
                            }
                            else
                            {
                                <div class="horarios-grid">
                                    @foreach (var horario in HorariosDisponibles)
                                    {
                                        <button type="button"
                                                class="@ObtenerClaseHorario(horario)"
                                                disabled="@(!horario.Disponible)"
                                                @onclick="() => SeleccionarHorario(horario)">
                                            <strong>@horario.Texto</strong>
                                            <span>@NombreConsultorioSeleccionado</span>
                                        </button>
                                    }
                                </div>

                                @if (HorarioSeleccionado)
                                {
                                    <div class="horario-seleccionado">
                                        Horario seleccionado:
                                        <strong>@HoraInicioTexto - @HoraFinTexto</strong>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="form-grid-full">
                        <label class="form-label">Motivo de consulta</label>
                        <InputTextArea class="form-control"
                                       rows="4"
                                       @bind-Value="Turno.MotivoConsulta"
                                       placeholder="Ej: Control general, dolor de garganta, consulta médica..." />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-outline" @onclick="Volver">
                        Cancelar
                    </button>

                    <button type="submit" class="btn btn-primary" disabled="@Guardando">
                        @TextoBotonGuardar
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter]
    public int? TurnoId { get; set; }

    private const int HoraInicioAgenda = 9;
    private const int HoraFinAgenda = 18;
    private const int DuracionTurnoMinutos = 30;

    private Turno Turno = new()
    {
        Estado = EstadoTurno.Confirmado
    };

    private List<Paciente> Pacientes = new();
    private List<Especialidad> Especialidades = new();
    private List<Medico> MedicosFiltrados = new();
    private List<Consultorio> Consultorios = new();
    private List<Turno> TurnosDelDia = new();
    private List<HorarioDisponibleItem> HorariosDisponibles = new();

    private int EspecialidadSeleccionadaId;

    private DateTime FechaTurno = DateTime.Today;
    private string HoraInicioTexto = string.Empty;
    private string HoraFinTexto = string.Empty;

    private bool Cargando = true;
    private bool CargandoHorarios;
    private bool Guardando;
    private bool HorarioSeleccionado;
    private string MensajeError = string.Empty;

    private bool EsEdicion => TurnoId.HasValue;

    private bool PuedeMostrarHorarios =>
        Turno.MedicoId > 0 &&
        Turno.ConsultorioId > 0;

    private string TituloPagina => EsEdicion ? "Editar turno" : "Nuevo turno";

    private string SubtituloPagina => EsEdicion
        ? "Actualizá los datos del turno seleccionado"
        : "Seleccioná fecha, horario y confirmá el turno";

    private string TextoBotonGuardar
    {
        get
        {
            if (Guardando)
                return EsEdicion ? "Guardando..." : "Confirmando...";

            return EsEdicion ? "Guardar cambios" : "Confirmar turno";
        }
    }

    private string TextoSelectorMedico
    {
        get
        {
            if (EspecialidadSeleccionadaId == 0)
                return "Primero seleccioná una especialidad";

            if (!MedicosFiltrados.Any())
                return "No hay médicos para esta especialidad";

            return "Seleccionar médico";
        }
    }

    private string NombreMedicoSeleccionado
    {
        get
        {
            var medico = MedicosFiltrados.FirstOrDefault(m => m.Id == Turno.MedicoId);
            return medico?.NombreCompleto ?? "Médico no seleccionado";
        }
    }

    private string NombreConsultorioSeleccionado
    {
        get
        {
            var consultorio = Consultorios.FirstOrDefault(c => c.Id == Turno.ConsultorioId);
            return consultorio?.Nombre ?? "Consultorio no seleccionado";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarDatosAsync();
    }

    private async Task CargarDatosAsync()
    {
        Cargando = true;
        MensajeError = string.Empty;

        var pacientesResponse = await PacienteService.ObtenerTodosAsync();
        var especialidadesResponse = await EspecialidadService.ObtenerTodosAsync();
        var consultoriosResponse = await ConsultorioService.ObtenerTodosAsync();

        if (!pacientesResponse.Exitoso)
        {
            MensajeError = pacientesResponse.Mensaje;
            Cargando = false;
            return;
        }

        if (!especialidadesResponse.Exitoso)
        {
            MensajeError = especialidadesResponse.Mensaje;
            Cargando = false;
            return;
        }

        if (!consultoriosResponse.Exitoso)
        {
            MensajeError = consultoriosResponse.Mensaje;
            Cargando = false;
            return;
        }

        Pacientes = pacientesResponse.Data ?? new List<Paciente>();
        Especialidades = especialidadesResponse.Data ?? new List<Especialidad>();
        Consultorios = consultoriosResponse.Data ?? new List<Consultorio>();
        MedicosFiltrados = new List<Medico>();

        if (EsEdicion)
        {
            await CargarTurnoParaEdicionAsync();
            HorarioSeleccionado = true;
        }

        await CargarTurnosDelDiaAsync();
        ActualizarHorariosDisponibles();

        Cargando = false;
    }

    private async Task CargarTurnoParaEdicionAsync()
    {
        var turnoResponse = await TurnoService.ObtenerPorIdAsync(TurnoId!.Value);

        if (!turnoResponse.Exitoso)
        {
            MensajeError = turnoResponse.Mensaje;
            Cargando = false;
            return;
        }

        Turno = turnoResponse.Data ?? new Turno();

        FechaTurno = Turno.Fecha.ToDateTime(TimeOnly.MinValue);
        HoraInicioTexto = Turno.HoraInicio.ToString("HH:mm");
        HoraFinTexto = Turno.HoraFin.ToString("HH:mm");

        if (Turno.Medico?.EspecialidadId > 0)
        {
            EspecialidadSeleccionadaId = Turno.Medico.EspecialidadId;
        }
        else if (Turno.Medico?.Especialidad?.Id > 0)
        {
            EspecialidadSeleccionadaId = Turno.Medico.Especialidad.Id;
        }

        if (EspecialidadSeleccionadaId > 0)
        {
            await CargarMedicosPorEspecialidadAsync(
                EspecialidadSeleccionadaId,
                mantenerMedicoSeleccionado: true);
        }
    }

    private async Task OnEspecialidadChanged(ChangeEventArgs e)
    {
        MensajeError = string.Empty;
        ReiniciarSeleccionHorario();

        if (!int.TryParse(e.Value?.ToString(), out var especialidadId) || especialidadId == 0)
        {
            EspecialidadSeleccionadaId = 0;
            Turno.MedicoId = 0;
            MedicosFiltrados = new List<Medico>();
            HorariosDisponibles = new List<HorarioDisponibleItem>();
            return;
        }

        EspecialidadSeleccionadaId = especialidadId;
        Turno.MedicoId = 0;

        await CargarMedicosPorEspecialidadAsync(especialidadId);
        await CargarTurnosDelDiaAsync();
        ActualizarHorariosDisponibles();
    }

    private async Task OnMedicoChanged(ChangeEventArgs e)
    {
        MensajeError = string.Empty;
        ReiniciarSeleccionHorario();

        Turno.MedicoId = int.TryParse(e.Value?.ToString(), out var medicoId)
            ? medicoId
            : 0;

        await CargarTurnosDelDiaAsync();
        ActualizarHorariosDisponibles();
    }

    private async Task OnConsultorioChanged(ChangeEventArgs e)
    {
        MensajeError = string.Empty;
        ReiniciarSeleccionHorario();

        Turno.ConsultorioId = int.TryParse(e.Value?.ToString(), out var consultorioId)
            ? consultorioId
            : 0;

        await CargarTurnosDelDiaAsync();
        ActualizarHorariosDisponibles();
    }

    private async Task OnFechaInputChangedAsync(ChangeEventArgs e)
    {
        MensajeError = string.Empty;
        ReiniciarSeleccionHorario();

        if (!DateTime.TryParse(e.Value?.ToString(), out var nuevaFecha))
        {
            MensajeError = "Seleccioná una fecha válida.";
            return;
        }

        FechaTurno = nuevaFecha;

        await CargarTurnosDelDiaAsync();
        ActualizarHorariosDisponibles();
    }

    private async Task CargarMedicosPorEspecialidadAsync(
        int especialidadId,
        bool mantenerMedicoSeleccionado = false)
    {
        var medicoIdActual = Turno.MedicoId;

        var medicosResponse = await MedicoService.ObtenerPorEspecialidadAsync(especialidadId);

        if (!medicosResponse.Exitoso)
        {
            MensajeError = medicosResponse.Mensaje;
            MedicosFiltrados = new List<Medico>();
            Turno.MedicoId = 0;
            return;
        }

        MedicosFiltrados = medicosResponse.Data?
            .OrderBy(m => m.NombreCompleto)
            .ToList() ?? new List<Medico>();

        if (mantenerMedicoSeleccionado && MedicosFiltrados.Any(m => m.Id == medicoIdActual))
        {
            Turno.MedicoId = medicoIdActual;
            return;
        }

        if (!mantenerMedicoSeleccionado)
        {
            Turno.MedicoId = 0;
        }

        if (!MedicosFiltrados.Any())
        {
            MensajeError = "No hay médicos registrados para la especialidad seleccionada.";
        }
    }

    private async Task CargarTurnosDelDiaAsync()
    {
        TurnosDelDia = new List<Turno>();

        if (!PuedeMostrarHorarios)
        {
            return;
        }

        CargandoHorarios = true;

        var fecha = DateOnly.FromDateTime(FechaTurno);
        var resultado = await TurnoService.ObtenerPorFechaAsync(fecha);

        if (!resultado.Exitoso)
        {
            MensajeError = resultado.Mensaje;
            CargandoHorarios = false;
            return;
        }

        TurnosDelDia = resultado.Data ?? new List<Turno>();
        CargandoHorarios = false;
    }

    private void ActualizarHorariosDisponibles()
    {
        if (!PuedeMostrarHorarios)
        {
            HorariosDisponibles = new List<HorarioDisponibleItem>();
            return;
        }

        HorariosDisponibles = GenerarHorariosDisponibles();
    }

    private List<HorarioDisponibleItem> GenerarHorariosDisponibles()
    {
        var horarios = new List<HorarioDisponibleItem>();

        var inicio = new TimeOnly(HoraInicioAgenda, 0);
        var finAgenda = new TimeOnly(HoraFinAgenda, 0);
        var duracion = TimeSpan.FromMinutes(DuracionTurnoMinutos);

        while (inicio.Add(duracion) <= finAgenda)
        {
            var fin = inicio.Add(duracion);
            var ocupado = HayConflictoDeHorario(inicio, fin);

            horarios.Add(new HorarioDisponibleItem
            {
                Inicio = inicio,
                Fin = fin,
                Disponible = !ocupado
            });

            inicio = fin;
        }

        return horarios;
    }

    private bool HayConflictoDeHorario(TimeOnly inicio, TimeOnly fin)
    {
        return TurnosDelDia.Any(turno =>
            turno.Id != Turno.Id &&
            TurnoBloqueaHorario(turno) &&
            (turno.MedicoId == Turno.MedicoId ||
             turno.ConsultorioId == Turno.ConsultorioId) &&
            HaySolapamiento(inicio, fin, turno.HoraInicio, turno.HoraFin));
    }

    private static bool HaySolapamiento(
        TimeOnly inicioNuevo,
        TimeOnly finNuevo,
        TimeOnly inicioExistente,
        TimeOnly finExistente)
    {
        return inicioNuevo < finExistente &&
               finNuevo > inicioExistente;
    }

    private static bool TurnoBloqueaHorario(Turno turno)
    {
        return turno.Estado != EstadoTurno.Cancelado &&
               turno.Estado != EstadoTurno.Ausente;
    }

    private void SeleccionarHorario(HorarioDisponibleItem horario)
    {
        if (!horario.Disponible)
        {
            return;
        }

        HoraInicioTexto = horario.Inicio.ToString("HH:mm");
        HoraFinTexto = horario.Fin.ToString("HH:mm");
        HorarioSeleccionado = true;
        MensajeError = string.Empty;
    }

    private void ReiniciarSeleccionHorario()
    {
        if (EsEdicion)
        {
            return;
        }

        HorarioSeleccionado = false;
        HoraInicioTexto = string.Empty;
        HoraFinTexto = string.Empty;
    }

    private async Task GuardarAsync()
    {
        Guardando = true;
        MensajeError = string.Empty;

        if (!ValidarFormulario())
        {
            Guardando = false;
            return;
        }

        Turno.Fecha = DateOnly.FromDateTime(FechaTurno);
        Turno.HoraInicio = TimeOnly.Parse(HoraInicioTexto);
        Turno.HoraFin = TimeOnly.Parse(HoraFinTexto);

        if (!EsEdicion)
        {
            Turno.Estado = EstadoTurno.Confirmado;
        }

        if (EsEdicion)
        {
            await ActualizarTurnoAsync();
        }
        else
        {
            await CrearTurnoAsync();
        }

        Guardando = false;
    }

    private bool ValidarFormulario()
    {
        if (Turno.PacienteId == 0)
        {
            MensajeError = "Seleccioná un paciente.";
            return false;
        }

        if (EspecialidadSeleccionadaId == 0)
        {
            MensajeError = "Seleccioná una especialidad.";
            return false;
        }

        if (Turno.MedicoId == 0)
        {
            MensajeError = "Seleccioná un médico.";
            return false;
        }

        if (Turno.ConsultorioId == 0)
        {
            MensajeError = "Seleccioná un consultorio.";
            return false;
        }

        if (!HorarioSeleccionado)
        {
            MensajeError = "Seleccioná un horario disponible.";
            return false;
        }

        if (!TimeOnly.TryParse(HoraInicioTexto, out var horaInicio))
        {
            MensajeError = "Seleccioná una hora de inicio válida.";
            return false;
        }

        if (!TimeOnly.TryParse(HoraFinTexto, out var horaFin))
        {
            MensajeError = "Seleccioná una hora de fin válida.";
            return false;
        }

        if (horaInicio >= horaFin)
        {
            MensajeError = "La hora de inicio debe ser menor que la hora de fin.";
            return false;
        }

        var horarioExiste = HorariosDisponibles.Any(h =>
            h.Disponible &&
            h.Inicio == horaInicio &&
            h.Fin == horaFin);

        if (!horarioExiste)
        {
            MensajeError = "El horario seleccionado ya no está disponible.";
            return false;
        }

        if (string.IsNullOrWhiteSpace(Turno.MotivoConsulta))
        {
            MensajeError = "Ingresá el motivo de consulta.";
            return false;
        }

        return true;
    }

    private async Task CrearTurnoAsync()
    {
        var resultado = await TurnoService.CrearAsync(Turno);

        if (!resultado.Exitoso)
        {
            await AlertService.ErrorAsync(
                "No se pudo confirmar el turno",
                resultado.Mensaje);

            return;
        }

        await AlertService.SuccessAsync(
            "Turno confirmado",
            "El turno quedó registrado correctamente.");

        Navigation.NavigateTo("/turnos");
    }

    private async Task ActualizarTurnoAsync()
    {
        var resultado = await TurnoService.ActualizarAsync(Turno.Id, Turno);

        if (!resultado.Exitoso)
        {
            await AlertService.ErrorAsync(
                "No se pudo actualizar el turno",
                resultado.Mensaje);

            return;
        }

        await AlertService.SuccessAsync(
            "Turno actualizado",
            "Los cambios se guardaron correctamente.");

        Navigation.NavigateTo("/turnos");
    }

    private string ObtenerClaseHorario(HorarioDisponibleItem horario)
    {
        var clase = horario.Disponible
            ? "horario-btn horario-btn-free"
            : "horario-btn horario-btn-busy";

        if (HorarioSeleccionado &&
            horario.Inicio.ToString("HH:mm") == HoraInicioTexto &&
            horario.Fin.ToString("HH:mm") == HoraFinTexto)
        {
            clase += " horario-btn-selected";
        }

        return clase;
    }

    private void Volver()
    {
        Navigation.NavigateTo("/turnos");
    }

    private class HorarioDisponibleItem
    {
        public TimeOnly Inicio { get; set; }
        public TimeOnly Fin { get; set; }
        public bool Disponible { get; set; }

        public string Texto => $"{Inicio:HH:mm} - {Fin:HH:mm}";
    }
}