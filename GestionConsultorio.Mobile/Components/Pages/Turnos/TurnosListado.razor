@page "/turnos"

@using GestionConsultorio.Mobile.Services.Interfaces
@using GestionConsultorio.Shared.Enums
@using GestionConsultorio.Shared.Models

@inject ITurnoService TurnoService
@inject IAlertService AlertService
@inject ISesionService SesionService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-title">
        <h2>Turnos</h2>
        <p>Gestión de turnos asignados en el consultorio</p>
    </div>

    @if (UsuarioEsAdministradorORecepcionista())
    {
        <button class="btn btn-primary" @onclick="IrNuevoTurno">
            + Nuevo turno
        </button>
    }
</div>

@if (!string.IsNullOrWhiteSpace(MensajeError))
{
    <div class="alert alert-error">
        @MensajeError
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="toolbar">
            <div class="turnos-filters">
                <div class="search-box">
                    <input class="form-control"
                           placeholder="Buscar paciente, médico o motivo..."
                           @bind="TextoBusqueda"
                           @bind:event="oninput" />
                </div>

                <InputDate class="form-control filter-date"
                           @bind-Value="FechaSeleccionada" />

                <button class="btn btn-outline" @onclick="CargarTurnosPorFechaAsync">
                    Filtrar fecha
                </button>

                <button class="btn btn-outline" @onclick="CargarTodosAsync">
                    Ver todos
                </button>
            </div>
        </div>

        @if (Cargando)
        {
            <p class="empty-text">Cargando turnos...</p>
        }
        else if (!TurnosFiltrados.Any())
        {
            <p class="empty-text">No se encontraron turnos.</p>
        }
        else
        {
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Fecha y hora</th>
                            <th>Paciente</th>
                            <th>Médico</th>
                            <th>Consultorio</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var turno in TurnosFiltrados)
                        {
                            <tr>
                                <td>
                                    <strong>@turno.Fecha.ToString("dd/MM/yyyy")</strong>
                                    <div class="table-subtext">
                                        @turno.HoraInicio.ToString("HH:mm") - @turno.HoraFin.ToString("HH:mm")
                                    </div>
                                </td>

                                <td>
                                    <strong>@(turno.Paciente?.NombreCompleto ?? "Sin paciente")</strong>
                                    <div class="table-subtext">
                                        DNI @(turno.Paciente?.Dni ?? "-")
                                    </div>
                                </td>

                                <td>
                                    <strong>@(turno.Medico?.NombreCompleto ?? "Sin médico")</strong>
                                    <div class="table-subtext">
                                        @(turno.Medico?.Especialidad?.Nombre ?? "Sin especialidad")
                                    </div>
                                </td>

                                <td>
                                    @(turno.Consultorio?.Nombre ?? "Sin consultorio")
                                </td>

                                <td>
                                    @MostrarDato(turno.MotivoConsulta)
                                </td>

                                <td>
                                    <span class="@ObtenerClaseEstado(turno.Estado)">
                                        @turno.Estado
                                    </span>
                                </td>

                                <td>
                                    @if (HayAccionesDisponibles(turno))
                                    {
                                        <div class="actions">
                                            @if (PuedeMarcarAusente(turno))
                                            {
                                                <button class="action-btn" @onclick="() => MarcarAusenteAsync(turno.Id)">
                                                    Ausente
                                                </button>
                                            }

                                            @if (PuedeEditar(turno))
                                            {
                                                <button class="action-btn" @onclick="() => EditarTurno(turno.Id)">
                                                    Editar
                                                </button>
                                            }

                                            @if (PuedeCancelar(turno))
                                            {
                                                <button class="action-btn action-danger" @onclick="() => CancelarAsync(turno.Id)">
                                                    Cancelar
                                                </button>
                                            }

                                            @if (PuedeEliminar())
                                            {
                                                <button class="action-btn action-danger" @onclick="() => EliminarAsync(turno.Id)">
                                                    Eliminar
                                                </button>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="table-subtext">Sin acciones</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool Cargando = true;
    private string MensajeError = string.Empty;
    private string TextoBusqueda = string.Empty;

    private DateTime FechaSeleccionada = DateTime.Today;

    private List<Turno> Turnos = new();

    private IEnumerable<Turno> TurnosFiltrados =>
        string.IsNullOrWhiteSpace(TextoBusqueda)
            ? Turnos
            : Turnos.Where(t =>
                (t.Paciente?.NombreCompleto?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (t.Paciente?.Dni?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (t.Medico?.NombreCompleto?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (t.MotivoConsulta?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await CargarTurnosPorFechaAsync();
    }

    private async Task CargarTodosAsync()
    {
        Cargando = true;
        MensajeError = string.Empty;

        var resultado = await TurnoService.ObtenerTodosAsync();

        if (!resultado.Exitoso)
        {
            MensajeError = resultado.Mensaje;
            Cargando = false;
            return;
        }

        Turnos = resultado.Data ?? new List<Turno>();
        Cargando = false;
    }

    private async Task CargarTurnosPorFechaAsync()
    {
        Cargando = true;
        MensajeError = string.Empty;

        var fecha = DateOnly.FromDateTime(FechaSeleccionada);

        var resultado = await TurnoService.ObtenerPorFechaAsync(fecha);

        if (!resultado.Exitoso)
        {
            MensajeError = resultado.Mensaje;
            Cargando = false;
            return;
        }

        Turnos = resultado.Data ?? new List<Turno>();
        Cargando = false;
    }

    private async Task MarcarAusenteAsync(int id)
    {
        var confirmado = await AlertService.ConfirmAsync(
            "Marcar ausente",
            "¿Seguro que querés marcar al paciente como ausente?",
            "Sí, marcar ausente");

        if (!confirmado)
        {
            return;
        }

        var resultado = await TurnoService.MarcarAusenteAsync(id);

        await ProcesarAccionAsync(
            resultado,
            "Paciente ausente",
            "El turno fue marcado como ausente.");
    }

    private async Task CancelarAsync(int id)
    {
        var confirmado = await AlertService.ConfirmAsync(
            "Cancelar turno",
            "¿Seguro que querés cancelar este turno?",
            "Sí, cancelar");

        if (!confirmado)
        {
            return;
        }

        var resultado = await TurnoService.CancelarAsync(id);

        await ProcesarAccionAsync(
            resultado,
            "Turno cancelado",
            "El turno fue cancelado correctamente.");
    }

    private async Task EliminarAsync(int id)
    {
        var confirmado = await AlertService.ConfirmAsync(
            "Eliminar turno",
            "¿Seguro que querés eliminar este turno?",
            "Sí, eliminar");

        if (!confirmado)
        {
            return;
        }

        var resultado = await TurnoService.EliminarAsync(id);

        await ProcesarAccionAsync(
            resultado,
            "Turno eliminado",
            "El turno fue eliminado correctamente.");
    }

    private async Task ProcesarAccionAsync(
        GestionConsultorio.Shared.Responses.ApiResponse<bool> resultado,
        string tituloExito,
        string mensajeExito)
    {
        MensajeError = string.Empty;

        if (!resultado.Exitoso)
        {
            await AlertService.ErrorAsync(
                "No se pudo completar la acción",
                resultado.Mensaje);

            return;
        }

        await AlertService.SuccessAsync(tituloExito, mensajeExito);
        await CargarTurnosPorFechaAsync();
    }

    private void IrNuevoTurno()
    {
        Navigation.NavigateTo("/turnos/nuevo");
    }

    private void EditarTurno(int id)
    {
        Navigation.NavigateTo($"/turnos/editar/{id}");
    }

    private bool HayAccionesDisponibles(Turno turno)
    {
        return PuedeMarcarAusente(turno) ||
               PuedeEditar(turno) ||
               PuedeCancelar(turno) ||
               PuedeEliminar();
    }

    private bool PuedeMarcarAusente(Turno turno)
    {
        return UsuarioEsAdministradorORecepcionista() &&
               TurnoActivo(turno);
    }

    private bool PuedeEditar(Turno turno)
    {
        return UsuarioEsAdministradorORecepcionista() &&
               TurnoActivo(turno);
    }

    private bool PuedeCancelar(Turno turno)
    {
        return UsuarioEsAdministradorORecepcionista() &&
               TurnoActivo(turno);
    }

    private bool PuedeEliminar()
    {
        return UsuarioEsAdministrador();
    }

    private bool TurnoActivo(Turno turno)
    {
        return turno.Estado == EstadoTurno.Pendiente ||
               turno.Estado == EstadoTurno.Confirmado;
    }

    private bool UsuarioEsAdministrador()
    {
        return string.Equals(
            SesionService.ObtenerRol(),
            "Administrador",
            StringComparison.OrdinalIgnoreCase);
    }

    private bool UsuarioEsRecepcionista()
    {
        return string.Equals(
            SesionService.ObtenerRol(),
            "Recepcionista",
            StringComparison.OrdinalIgnoreCase);
    }

    private bool UsuarioEsAdministradorORecepcionista()
    {
        return UsuarioEsAdministrador() || UsuarioEsRecepcionista();
    }

    private static string MostrarDato(string? valor)
    {
        return string.IsNullOrWhiteSpace(valor) ? "-" : valor;
    }

    private static string ObtenerClaseEstado(EstadoTurno estado)
    {
        return estado switch
        {
            EstadoTurno.Confirmado => "badge badge-success",
            EstadoTurno.Pendiente => "badge badge-warning",
            EstadoTurno.Cancelado => "badge badge-danger",
            EstadoTurno.Atendido => "badge badge-info",
            EstadoTurno.Ausente => "badge badge-danger",
            EstadoTurno.Reprogramado => "badge badge-warning",
            _ => "badge badge-info"
        };
    }
}