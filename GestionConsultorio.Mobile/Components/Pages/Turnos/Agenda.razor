@page "/agenda"

@using GestionConsultorio.Mobile.Services.Interfaces
@using GestionConsultorio.Shared.Enums
@using GestionConsultorio.Shared.Models

@inject ITurnoService TurnoService
@inject IAlertService AlertService
@inject ISesionService SesionService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-title">
        <h2>Agenda</h2>
        <p>Vista diaria de turnos programados</p>
    </div>

    @if (UsuarioEsRecepcionista())
    {
        <button class="btn btn-primary" @onclick="IrNuevoTurno">
            + Nuevo turno
        </button>
    }
</div>

@if (!string.IsNullOrWhiteSpace(MensajeError))
{
    <div class="alert alert-error">
        @MensajeError
    </div>
}

@if (!UsuarioPuedeVerAgenda())
{
    <div class="card">
        <div class="card-body">
            <p class="empty-text">No tenés permisos para ver la agenda.</p>
        </div>
    </div>
}
else
{
    <div class="agenda-grid">
        <div class="card agenda-day-card">
            <div class="agenda-date-box">
                <span>Fecha seleccionada</span>
                <strong>@FechaSeleccionada.ToString("dd/MM/yyyy")</strong>
            </div>

            <div class="agenda-date-control">
                <label class="form-label">Cambiar fecha</label>
                <InputDate class="form-control" @bind-Value="FechaSeleccionada" />
            </div>

            <div class="agenda-view-action">
                <button class="btn btn-primary" @onclick="CargarAgendaAsync">
                    Ver agenda
                </button>
            </div>

            <div class="agenda-summary">
                <div>
                    <span>Total turnos</span>
                    <strong>@Turnos.Count</strong>
                </div>

                <div>
                    <span>Pendientes</span>
                    <strong>@CantidadPendientes</strong>
                </div>

                <div>
                    <span>Confirmados</span>
                    <strong>@CantidadConfirmados</strong>
                </div>

                <div>
                    <span>Atendidos</span>
                    <strong>@CantidadAtendidos</strong>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="section-header">
                    <div>
                        <h3>Turnos del día</h3>
                        <p>Agenda correspondiente al @FechaSeleccionada.ToString("dd/MM/yyyy")</p>
                    </div>

                    <button class="btn btn-outline" @onclick="CargarAgendaAsync">
                        Actualizar
                    </button>
                </div>

                @if (Cargando)
                {
                    <p class="empty-text">Cargando agenda...</p>
                }
                else if (!Turnos.Any())
                {
                    <p class="empty-text">No hay turnos programados para esta fecha.</p>
                }
                else
                {
                    <div class="agenda-timeline">
                        @foreach (var turno in TurnosOrdenados)
                        {
                            <div class="agenda-timeline-item">
                                <div class="agenda-hour">
                                    @turno.HoraInicio.ToString("HH:mm")
                                </div>

                                <div class="agenda-card">
                                    <div class="agenda-card-header">
                                        <div>
                                            <strong>@(turno.Paciente?.NombreCompleto ?? "Paciente sin cargar")</strong>
                                            <span>@turno.HoraInicio.ToString("HH:mm") - @turno.HoraFin.ToString("HH:mm")</span>
                                        </div>

                                        <span class="@ObtenerClaseEstado(turno.Estado)">
                                            @turno.Estado
                                        </span>
                                    </div>

                                    <div class="agenda-info-grid">
                                        <div>
                                            <span>Médico</span>
                                            <strong>@(turno.Medico?.NombreCompleto ?? "Sin médico")</strong>
                                        </div>

                                        <div>
                                            <span>Especialidad</span>
                                            <strong>@(turno.Medico?.Especialidad?.Nombre ?? "Sin especialidad")</strong>
                                        </div>

                                        <div>
                                            <span>Consultorio</span>
                                            <strong>@(turno.Consultorio?.Nombre ?? "Sin consultorio")</strong>
                                        </div>

                                        <div>
                                            <span>Estado</span>
                                            <strong>@turno.Estado</strong>
                                        </div>
                                    </div>

                                    @if (TieneAcciones(turno))
                                    {
                                        <div class="actions agenda-actions">
                                            @if (PuedeAtender(turno))
                                            {
                                                <button class="action-btn" @onclick="@(() => IrAtenderTurno(turno.Id))">
                                                    Atender
                                                </button>
                                            }

                                            @if (PuedeMarcarAusente(turno))
                                            {
                                                <button class="action-btn action-warning" @onclick="@(() => MarcarAusenteAsync(turno.Id))">
                                                    Ausente
                                                </button>
                                            }

                                            @if (PuedeEditar(turno))
                                            {
                                                <button class="action-btn" @onclick="@(() => EditarTurno(turno.Id))">
                                                    Editar
                                                </button>
                                            }

                                            @if (PuedeCancelar(turno))
                                            {
                                                <button class="action-btn action-danger" @onclick="@(() => CancelarAsync(turno.Id))">
                                                    Cancelar
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool Cargando = true;
    private string MensajeError = string.Empty;

    private DateTime FechaSeleccionada = DateTime.Today;
    private List<Turno> Turnos = new();

    private IEnumerable<Turno> TurnosOrdenados =>
        Turnos.OrderBy(t => t.HoraInicio);

    private int CantidadPendientes =>
        Turnos.Count(t => t.Estado == EstadoTurno.Pendiente);

    private int CantidadConfirmados =>
        Turnos.Count(t => t.Estado == EstadoTurno.Confirmado);

    private int CantidadAtendidos =>
        Turnos.Count(t => t.Estado == EstadoTurno.Atendido);

    protected override async Task OnInitializedAsync()
    {
        if (!UsuarioPuedeVerAgenda())
        {
            Cargando = false;
            return;
        }

        await CargarAgendaAsync();
    }

    private async Task CargarAgendaAsync()
    {
        if (!UsuarioPuedeVerAgenda())
        {
            MensajeError = "No tenés permisos para ver la agenda.";
            Cargando = false;
            return;
        }

        Cargando = true;
        MensajeError = string.Empty;

        var fecha = DateOnly.FromDateTime(FechaSeleccionada);
        var resultado = await TurnoService.ObtenerPorFechaAsync(fecha);

        if (!resultado.Exitoso)
        {
            MensajeError = resultado.Mensaje;
            Cargando = false;
            return;
        }

        Turnos = resultado.Data ?? new List<Turno>();
        Cargando = false;
    }

    private async Task MarcarAusenteAsync(int id)
    {
        var confirmado = await AlertService.ConfirmAsync(
            "Marcar ausente",
            "¿Seguro que querés marcar al paciente como ausente?",
            "Sí, marcar ausente");

        if (!confirmado)
        {
            return;
        }

        var resultado = await TurnoService.MarcarAusenteAsync(id);

        await ProcesarAccionAsync(
            resultado,
            "Paciente ausente",
            "El turno fue marcado como ausente.");
    }

    private async Task CancelarAsync(int id)
    {
        var confirmado = await AlertService.ConfirmAsync(
            "Cancelar turno",
            "¿Seguro que querés cancelar este turno?",
            "Sí, cancelar");

        if (!confirmado)
        {
            return;
        }

        var resultado = await TurnoService.CancelarAsync(id);

        await ProcesarAccionAsync(
            resultado,
            "Turno cancelado",
            "El turno fue cancelado correctamente.");
    }

    private async Task ProcesarAccionAsync(
        GestionConsultorio.Shared.Responses.ApiResponse<bool> resultado,
        string tituloExito,
        string mensajeExito)
    {
        MensajeError = string.Empty;

        if (!resultado.Exitoso)
        {
            await AlertService.ErrorAsync(
                "No se pudo completar la acción",
                resultado.Mensaje);

            return;
        }

        await AlertService.SuccessAsync(tituloExito, mensajeExito);
        await CargarAgendaAsync();
    }

    private void IrNuevoTurno()
    {
        Navigation.NavigateTo("/turnos/nuevo");
    }

    private void EditarTurno(int id)
    {
        Navigation.NavigateTo($"/turnos/editar/{id}");
    }

    private void IrAtenderTurno(int id)
    {
        Navigation.NavigateTo($"/turnos/atender/{id}");
    }

    private bool TieneAcciones(Turno turno)
    {
        return PuedeAtender(turno) ||
               PuedeMarcarAusente(turno) ||
               PuedeEditar(turno) ||
               PuedeCancelar(turno);
    }

    private bool PuedeAtender(Turno turno)
    {
        return UsuarioEsMedico() &&
               TurnoDisponibleParaAccionMedica(turno);
    }

    private bool PuedeMarcarAusente(Turno turno)
    {
        return UsuarioEsMedico() &&
               TurnoDisponibleParaAccionMedica(turno);
    }

    private bool PuedeEditar(Turno turno)
    {
        return UsuarioEsRecepcionista() &&
               TurnoDisponibleParaGestion(turno);
    }

    private bool PuedeCancelar(Turno turno)
    {
        return UsuarioEsRecepcionista() &&
               TurnoDisponibleParaGestion(turno);
    }

    private static bool TurnoDisponibleParaAccionMedica(Turno turno)
    {
        return turno.Estado == EstadoTurno.Pendiente ||
               turno.Estado == EstadoTurno.Confirmado;
    }

    private static bool TurnoDisponibleParaGestion(Turno turno)
    {
        return turno.Estado == EstadoTurno.Pendiente ||
               turno.Estado == EstadoTurno.Confirmado;
    }

    private bool UsuarioPuedeVerAgenda()
    {
        return UsuarioEsRecepcionista() || UsuarioEsMedico();
    }

    private bool UsuarioEsMedico()
    {
        return string.Equals(
            SesionService.ObtenerRol(),
            "Medico",
            StringComparison.OrdinalIgnoreCase);
    }

    private bool UsuarioEsRecepcionista()
    {
        return string.Equals(
            SesionService.ObtenerRol(),
            "Recepcionista",
            StringComparison.OrdinalIgnoreCase);
    }

    private static string ObtenerClaseEstado(EstadoTurno estado)
    {
        return estado switch
        {
            EstadoTurno.Confirmado => "badge badge-success",
            EstadoTurno.Pendiente => "badge badge-warning",
            EstadoTurno.Cancelado => "badge badge-danger",
            EstadoTurno.Atendido => "badge badge-info",
            EstadoTurno.Ausente => "badge badge-danger",
            EstadoTurno.Reprogramado => "badge badge-warning",
            _ => "badge badge-info"
        };
    }
}