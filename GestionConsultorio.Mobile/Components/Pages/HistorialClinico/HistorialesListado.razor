@page "/historiales"
@page "/historiales/paciente/{PacienteId:int}"

@using GestionConsultorio.Mobile.Services.Interfaces
@using GestionConsultorio.Shared.Models
@using Microsoft.AspNetCore.Components.Forms

@inject IHistorialClinicoService HistorialClinicoService
@inject IArchivoHistorialClinicoService ArchivoHistorialClinicoService
@inject IAlertService AlertService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-title">
        <h2>@TituloPagina</h2>
        <p>@SubtituloPagina</p>
    </div>

    @if (EsHistorialDePaciente)
    {
        <button class="btn btn-outline" @onclick="VolverAPacientes">
            Volver
        </button>
    }
</div>

@if (!string.IsNullOrWhiteSpace(MensajeError))
{
    <div class="alert alert-error">
        @MensajeError
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="toolbar">
            <div class="search-box">
                <input class="form-control"
                       placeholder="Buscar por paciente, diagnóstico o tratamiento..."
                       @bind="TextoBusqueda"
                       @bind:event="oninput" />
            </div>

            <button class="btn btn-outline" @onclick="CargarHistorialesAsync">
                Actualizar
            </button>
        </div>

        @if (Cargando)
        {
            <p class="empty-text">Cargando historiales clínicos...</p>
        }
        else if (!HistorialesFiltrados.Any())
        {
            <p class="empty-text">No se encontraron registros clínicos.</p>
        }
        else
        {
            <div class="history-list">
                @foreach (var historial in HistorialesFiltrados)
                {
                    <div class="history-card">
                        <div class="history-card-header">
                            <div>
                                <h3>@(historial.Paciente?.NombreCompleto ?? "Paciente sin cargar")</h3>
                                <p>
                                    Registro del @historial.FechaRegistro.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            </div>

                            <span class="badge badge-info">
                                Historial clínico
                            </span>
                        </div>

                        <div class="history-info-grid">
                            <div>
                                <span>Diagnóstico</span>
                                <strong>@MostrarDato(historial.Diagnostico)</strong>
                            </div>

                            <div>
                                <span>Tratamiento</span>
                                <strong>@MostrarDato(historial.Tratamiento)</strong>
                            </div>

                            <div>
                                <span>Turno</span>
                                <strong>
                                    @if (historial.Turno is not null)
                                    {
                                        @($"{historial.Turno.Fecha:dd/MM/yyyy} - {historial.Turno.HoraInicio:HH:mm}")
                                    }
                                    else
                                    {
                                        @("Sin turno")
                                    }
                                </strong>
                            </div>

                            <div>
                                <span>Médico</span>
                                <strong>
                                    @(historial.Turno?.Medico?.NombreCompleto ?? "Sin médico")
                                </strong>
                            </div>
                        </div>

                        <div class="history-observations">
                            <span>Observaciones</span>
                            <p>@MostrarDato(historial.Observaciones, "Sin observaciones registradas.")</p>
                        </div>

                        <div class="attachments-panel">
                            <div class="attachments-header">
                                <div>
                                    <h4>Archivos adjuntos</h4>
                                    <p>Estudios, imágenes o documentos relacionados con el historial clínico.</p>
                                </div>

                                <span class="attachments-count">
                                    @(historial.Archivos?.Count ?? 0) archivo(s)
                                </span>
                            </div>

                            @if (historial.Archivos is not null && historial.Archivos.Any())
                            {
                                <div class="attachments-list">
                                    @foreach (var archivo in historial.Archivos.OrderByDescending(a => a.FechaCarga))
                                    {
                                        <div class="attachment-item">
                                            <div class="attachment-icon">
                                                @ObtenerIconoArchivo(archivo.TipoContenido)
                                            </div>

                                            <div class="attachment-content">
                                                <strong>@archivo.NombreArchivo</strong>

                                                <span>
                                                    @MostrarDato(archivo.TipoContenido)
                                                    ·
                                                    @FormatearTamanio(archivo.TamanioBytes)
                                                    ·
                                                    @archivo.FechaCarga.ToString("dd/MM/yyyy HH:mm")
                                                </span>
                                            </div>

                                            <div class="attachment-actions">
                                                <a class="action-btn"
                                                   href="@archivo.Url"
                                                   target="_blank">
                                                    Ver
                                                </a>

                                                <button class="action-btn action-danger"
                                                        @onclick="@(() => EliminarArchivoAsync(archivo.Id))">
                                                    Eliminar
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="attachments-empty">
                                    <div class="attachment-icon empty-icon">
                                        📎
                                    </div>

                                    <div>
                                        <strong>Sin archivos adjuntos</strong>
                                        <span>Podés subir imágenes, estudios o documentos PDF.</span>
                                    </div>
                                </div>
                            }

                            <div class="file-upload-card">
                                <div class="file-upload-info">
                                    <strong>Adjuntar archivo</strong>
                                    <span>Formatos permitidos: JPG, PNG, WEBP o PDF.</span>
                                </div>

                                <label class="file-upload-button">
                                    <span>Seleccionar archivo</span>

                                    <InputFile class="file-upload-input"
                                               OnChange="@(e => SubirArchivoAsync(historial.Id, e))"
                                               accept=".jpg,.jpeg,.png,.webp,.pdf,image/*,application/pdf" />
                                </label>
                            </div>

                            @if (HistorialSubiendoId == historial.Id)
                            {
                                <div class="uploading-state">
                                    <span class="uploading-dot"></span>
                                    Subiendo archivo...
                                </div>
                            }
                        </div>

                        <div class="actions history-actions">
                            <button class="action-btn" @onclick="@(() => EditarHistorial(historial.Id))">
                                Editar
                            </button>

                            <button class="action-btn action-danger" @onclick="@(() => EliminarHistorialAsync(historial.Id))">
                                Eliminar
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public int? PacienteId { get; set; }

    private bool EsHistorialDePaciente => PacienteId.HasValue;

    private string TituloPagina =>
        EsHistorialDePaciente
            ? "Historial clínico del paciente"
            : "Historial clínico";

    private string SubtituloPagina =>
        EsHistorialDePaciente
            ? "Registros médicos asociados al paciente seleccionado"
            : "Registros médicos asociados a pacientes y turnos atendidos";

    private bool Cargando = true;
    private string MensajeError = string.Empty;
    private string TextoBusqueda = string.Empty;

    private int? HistorialSubiendoId;

    private List<HistorialClinico> Historiales = new();

    private IEnumerable<HistorialClinico> HistorialesFiltrados =>
        string.IsNullOrWhiteSpace(TextoBusqueda)
            ? Historiales
            : Historiales.Where(h =>
                (h.Paciente?.NombreCompleto?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (h.Diagnostico?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (h.Tratamiento?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (h.Observaciones?.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await CargarHistorialesAsync();
    }

    private async Task CargarHistorialesAsync()
    {
        Cargando = true;
        MensajeError = string.Empty;

        var resultado = EsHistorialDePaciente
            ? await HistorialClinicoService.ObtenerPorPacienteAsync(PacienteId!.Value)
            : await HistorialClinicoService.ObtenerTodosAsync();

        if (!resultado.Exitoso)
        {
            MensajeError = resultado.Mensaje;
            Cargando = false;
            return;
        }

        Historiales = resultado.Data ?? new List<HistorialClinico>();
        Cargando = false;
    }

    private void EditarHistorial(int id)
    {
        Navigation.NavigateTo($"/historiales/editar/{id}");
    }

    private async Task EliminarHistorialAsync(int id)
    {
        MensajeError = string.Empty;

        var confirmado = await AlertService.ConfirmAsync(
            "Eliminar historial clínico",
            "¿Seguro que querés eliminar este registro clínico?",
            "Sí, eliminar");

        if (!confirmado)
        {
            return;
        }

        var resultado = await HistorialClinicoService.EliminarAsync(id);

        if (!resultado.Exitoso)
        {
            await AlertService.ErrorAsync(
                "No se pudo eliminar",
                resultado.Mensaje);

            return;
        }

        await AlertService.SuccessAsync(
            "Historial eliminado",
            "El historial clínico se eliminó correctamente.");

        await CargarHistorialesAsync();
    }

    private async Task SubirArchivoAsync(int historialClinicoId, InputFileChangeEventArgs e)
    {
        MensajeError = string.Empty;
        HistorialSubiendoId = historialClinicoId;

        var archivo = e.File;

        if (archivo is null)
        {
            HistorialSubiendoId = null;

            await AlertService.ErrorAsync(
                "Archivo inválido",
                "Debe seleccionar un archivo.");

            return;
        }

        var resultado = await ArchivoHistorialClinicoService.SubirArchivoAsync(
            historialClinicoId,
            archivo);

        HistorialSubiendoId = null;

        if (!resultado.Exitoso)
        {
            await AlertService.ErrorAsync(
                "No se pudo subir el archivo",
                resultado.Mensaje);

            return;
        }

        await AlertService.SuccessAsync(
            "Archivo subido",
            "El archivo se adjuntó correctamente al historial clínico.");

        await CargarHistorialesAsync();
    }

    private async Task EliminarArchivoAsync(int archivoId)
    {
        MensajeError = string.Empty;

        var confirmado = await AlertService.ConfirmAsync(
            "Eliminar archivo",
            "¿Seguro que querés eliminar este archivo adjunto?",
            "Sí, eliminar");

        if (!confirmado)
        {
            return;
        }

        var resultado = await ArchivoHistorialClinicoService.EliminarAsync(archivoId);

        if (!resultado.Exitoso)
        {
            await AlertService.ErrorAsync(
                "No se pudo eliminar el archivo",
                resultado.Mensaje);

            return;
        }

        await AlertService.SuccessAsync(
            "Archivo eliminado",
            "El archivo se eliminó correctamente.");

        await CargarHistorialesAsync();
    }

    private void VolverAPacientes()
    {
        if (PacienteId.HasValue)
        {
            Navigation.NavigateTo($"/pacientes/{PacienteId.Value}");
            return;
        }

        Navigation.NavigateTo("/pacientes");
    }

    private static string MostrarDato(string? valor, string textoAlternativo = "-")
    {
        return string.IsNullOrWhiteSpace(valor) ? textoAlternativo : valor;
    }

    private static string FormatearTamanio(long bytes)
    {
        if (bytes <= 0)
            return "-";

        if (bytes < 1024)
            return $"{bytes} B";

        if (bytes < 1024 * 1024)
            return $"{bytes / 1024.0:F1} KB";

        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }

    private static string ObtenerIconoArchivo(string? tipoContenido)
    {
        if (string.IsNullOrWhiteSpace(tipoContenido))
            return "📎";

        if (tipoContenido.Contains("pdf", StringComparison.OrdinalIgnoreCase))
            return "📄";

        if (tipoContenido.Contains("image", StringComparison.OrdinalIgnoreCase))
            return "🖼️";

        return "📎";
    }
}