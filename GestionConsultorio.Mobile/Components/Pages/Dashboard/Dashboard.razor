@page "/dashboard"

@using GestionConsultorio.Mobile.Services.Interfaces
@using GestionConsultorio.Shared.Enums
@using GestionConsultorio.Shared.Models

@inject IPacienteService PacienteService
@inject IMedicoService MedicoService
@inject ITurnoService TurnoService
@inject IConsultorioService ConsultorioService
@inject IEspecialidadService EspecialidadService
@inject ISesionService SesionService
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-title">
        <h2>Inicio</h2>
        <p>@SubtituloDashboard</p>
    </div>

    @if (PuedeCrearTurnos)
    {
        <button class="btn btn-primary" @onclick="IrNuevoTurno">
            + Nuevo turno
        </button>
    }
</div>

@if (!string.IsNullOrWhiteSpace(MensajeError))
{
    <div class="alert alert-error">
        @MensajeError
    </div>
}

<div class="stats-grid">
    @if (PuedeVerTurnosHoy)
    {
        <div class="stat-card">
            <span>Turnos de hoy</span>
            <strong>@TurnosHoy.Count</strong>
        </div>
    }

    @if (PuedeVerPacientes)
    {
        <div class="stat-card">
            <span>Pacientes registrados</span>
            <strong>@CantidadPacientes</strong>
        </div>
    }

    @if (PuedeVerMedicos)
    {
        <div class="stat-card">
            <span>Médicos activos</span>
            <strong>@CantidadMedicos</strong>
        </div>
    }

    @if (PuedeVerEspecialidades)
    {
        <div class="stat-card">
            <span>Especialidades</span>
            <strong>@CantidadEspecialidades</strong>
        </div>
    }

    @if (PuedeVerConsultorios)
    {
        <div class="stat-card">
            <span>Consultorios</span>
            <strong>@CantidadConsultorios</strong>
        </div>
    }

    @if (EsMedico)
    {
        <div class="stat-card">
            <span>Rol actual</span>
            <strong>Médico</strong>
        </div>
    }
</div>

<div class="dashboard-grid">
    @if (PuedeVerAgenda)
    {
        <div class="card">
            <div class="card-body">
                <div class="section-header">
                    <div>
                        <h3>Agenda de hoy</h3>
                        <p>Turnos programados para @FechaHoyTexto</p>
                    </div>

                    <button class="btn btn-outline" @onclick="IrAgenda">
                        Ver agenda
                    </button>
                </div>

                @if (Cargando)
                {
                    <p class="empty-text">Cargando información...</p>
                }
                else if (!TurnosHoy.Any())
                {
                    <p class="empty-text">No hay turnos cargados para hoy.</p>
                }
                else
                {
                    @foreach (var turno in TurnosHoy)
                    {
                        <div class="turno-item">
                            <div class="turno-item-header">
                                <span class="turno-time">
                                    @turno.HoraInicio.ToString("HH:mm") - @turno.HoraFin.ToString("HH:mm")
                                </span>

                                <span class="@ObtenerClaseEstado(turno.Estado)">
                                    @turno.Estado
                                </span>
                            </div>

                            <div class="turno-patient">
                                @(turno.Paciente?.NombreCompleto ?? "Paciente sin cargar")
                            </div>

                            <div class="turno-detail">
                                Médico: @(turno.Medico?.NombreCompleto ?? "Sin médico")
                            </div>

                            <div class="turno-detail">
                                Consultorio: @(turno.Consultorio?.Nombre ?? "Sin consultorio")
                            </div>

                            <div class="turno-detail">
                                Motivo: @MostrarDato(turno.MotivoConsulta)
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @if (EsAdministrador)
    {
        <div class="card">
            <div class="card-body">
                <div class="section-header">
                    <div>
                        <h3>Panel administrativo</h3>
                        <p>Gestión de configuración del consultorio</p>
                    </div>
                </div>

                @if (Cargando)
                {
                    <p class="empty-text">Cargando información...</p>
                }
                else
                {
                    <div class="quick-actions">
                        <button class="quick-action-card" @onclick="IrMedicos">
                            <span>👨‍⚕️</span>
                            <strong>Médicos</strong>
                            <small>Gestionar profesionales y accesos médicos</small>
                        </button>

                        <button class="quick-action-card" @onclick="IrEspecialidades">
                            <span>🏥</span>
                            <strong>Especialidades</strong>
                            <small>Administrar áreas médicas</small>
                        </button>

                        <button class="quick-action-card" @onclick="IrConsultorios">
                            <span>🚪</span>
                            <strong>Consultorios</strong>
                            <small>Gestionar espacios de atención</small>
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    @if (!EsAdministrador)
    {
        <div class="card">
            <div class="card-body">
                <div class="section-header">
                    <div>
                        <h3>Accesos rápidos</h3>
                        <p>Operaciones disponibles para tu rol</p>
                    </div>
                </div>

                @if (Cargando)
                {
                    <p class="empty-text">Cargando información...</p>
                }
                else
                {
                    <div class="quick-actions">
                        @if (PuedeVerPacientes)
                        {
                            <button class="quick-action-card" @onclick="IrPacientes">
                                <span>👥</span>
                                <strong>Pacientes</strong>
                                <small>Registrar y consultar pacientes</small>
                            </button>
                        }

                        @if (PuedeVerTurnos)
                        {
                            <button class="quick-action-card" @onclick="IrTurnos">
                                <span>🕒</span>
                                <strong>Turnos</strong>
                                <small>Administrar turnos</small>
                            </button>
                        }

                        @if (PuedeVerAgenda)
                        {
                            <button class="quick-action-card" @onclick="IrAgenda">
                                <span>📅</span>
                                <strong>Agenda</strong>
                                <small>Consultar agenda diaria</small>
                            </button>
                        }

                        @if (PuedeVerHistoriales)
                        {
                            <button class="quick-action-card" @onclick="IrHistoriales">
                                <span>📋</span>
                                <strong>Historial clínico</strong>
                                <small>Consultar registros médicos</small>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool Cargando = true;
    private string MensajeError = string.Empty;

    private int CantidadPacientes;
    private int CantidadMedicos;
    private int CantidadEspecialidades;
    private int CantidadConsultorios;

    private string RolUsuario = string.Empty;

    private List<Turno> TurnosHoy = new();

    private DateOnly FechaHoy = DateOnly.FromDateTime(DateTime.Today);

    private string FechaHoyTexto => DateTime.Today.ToString("dd/MM/yyyy");

    private bool EsAdministrador =>
        string.Equals(RolUsuario, "Administrador", StringComparison.OrdinalIgnoreCase);

    private bool EsRecepcionista =>
        string.Equals(RolUsuario, "Recepcionista", StringComparison.OrdinalIgnoreCase);

    private bool EsMedico =>
        string.Equals(RolUsuario, "Medico", StringComparison.OrdinalIgnoreCase);

    private bool PuedeCrearTurnos =>
        EsRecepcionista;

    private bool PuedeVerTurnosHoy =>
        EsRecepcionista || EsMedico;

    private bool PuedeVerAgenda =>
        EsRecepcionista || EsMedico;

    private bool PuedeVerTurnos =>
        EsRecepcionista;

    private bool PuedeVerPacientes =>
        EsRecepcionista;

    private bool PuedeVerMedicos =>
        EsAdministrador;

    private bool PuedeVerEspecialidades =>
        EsAdministrador;

    private bool PuedeVerConsultorios =>
        EsAdministrador;

    private bool PuedeVerHistoriales =>
        EsMedico;

    private string SubtituloDashboard
    {
        get
        {
            if (EsAdministrador)
                return "Panel de administración y configuración del sistema";

            if (EsRecepcionista)
                return "Resumen operativo de pacientes, turnos y agenda";

            if (EsMedico)
                return "Resumen de agenda e historiales clínicos";

            return "Resumen del sistema";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        RolUsuario = SesionService.ObtenerRol() ?? string.Empty;
        await CargarDashboardAsync();
    }

    private async Task CargarDashboardAsync()
    {
        Cargando = true;
        MensajeError = string.Empty;

        if (PuedeVerTurnosHoy)
        {
            var turnosResponse = await TurnoService.ObtenerPorFechaAsync(FechaHoy);

            if (!turnosResponse.Exitoso)
            {
                MensajeError = turnosResponse.Mensaje;
                Cargando = false;
                return;
            }

            TurnosHoy = turnosResponse.Data ?? new List<Turno>();
        }

        if (PuedeVerPacientes)
        {
            var pacientesResponse = await PacienteService.ObtenerTodosAsync();

            if (!pacientesResponse.Exitoso)
            {
                MensajeError = pacientesResponse.Mensaje;
                Cargando = false;
                return;
            }

            CantidadPacientes = pacientesResponse.Data?.Count ?? 0;
        }

        if (PuedeVerMedicos)
        {
            var medicosResponse = await MedicoService.ObtenerTodosAsync();

            if (!medicosResponse.Exitoso)
            {
                MensajeError = medicosResponse.Mensaje;
                Cargando = false;
                return;
            }

            CantidadMedicos = medicosResponse.Data?.Count ?? 0;
        }

        if (PuedeVerEspecialidades)
        {
            var especialidadesResponse = await EspecialidadService.ObtenerTodosAsync();

            if (!especialidadesResponse.Exitoso)
            {
                MensajeError = especialidadesResponse.Mensaje;
                Cargando = false;
                return;
            }

            CantidadEspecialidades = especialidadesResponse.Data?.Count ?? 0;
        }

        if (PuedeVerConsultorios)
        {
            var consultoriosResponse = await ConsultorioService.ObtenerTodosAsync();

            if (!consultoriosResponse.Exitoso)
            {
                MensajeError = consultoriosResponse.Mensaje;
                Cargando = false;
                return;
            }

            CantidadConsultorios = consultoriosResponse.Data?.Count ?? 0;
        }

        Cargando = false;
    }

    private static string ObtenerClaseEstado(EstadoTurno estado)
    {
        return estado switch
        {
            EstadoTurno.Confirmado => "badge badge-success",
            EstadoTurno.Pendiente => "badge badge-warning",
            EstadoTurno.Cancelado => "badge badge-danger",
            EstadoTurno.Atendido => "badge badge-info",
            EstadoTurno.Ausente => "badge badge-danger",
            EstadoTurno.Reprogramado => "badge badge-warning",
            _ => "badge badge-info"
        };
    }

    private static string MostrarDato(string? valor)
    {
        return string.IsNullOrWhiteSpace(valor) ? "-" : valor;
    }

    private void IrNuevoTurno()
    {
        Navigation.NavigateTo("/turnos/nuevo");
    }

    private void IrAgenda()
    {
        Navigation.NavigateTo("/agenda");
    }

    private void IrPacientes()
    {
        Navigation.NavigateTo("/pacientes");
    }

    private void IrMedicos()
    {
        Navigation.NavigateTo("/medicos");
    }

    private void IrEspecialidades()
    {
        Navigation.NavigateTo("/especialidades");
    }

    private void IrConsultorios()
    {
        Navigation.NavigateTo("/consultorios");
    }

    private void IrTurnos()
    {
        Navigation.NavigateTo("/turnos");
    }

    private void IrHistoriales()
    {
        Navigation.NavigateTo("/historiales");
    }
}